# Environment Configuration Example
# Copy this file to .env and fill in your values

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=mycee-stock-control-secret-key-2026

# Database Configuration
DATABASE_URL=sqlite:///instance/mycee_stock.db
SQLALCHEMY_TRACK_MODIFICATIONS=False

# Email Configuration (for backups)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=myceeaccessories@gmail.com
MAIL_PASSWORD=your-gmail-app-password-here
MAIL_DEFAULT_SENDER=myceeaccessories@gmail.com

# Session Configuration
SESSION_TIMEOUT=604800  # 7 days in seconds

# Low Stock Alert Threshold
LOW_STOCK_THRESHOLD=10

# Application Settings
APP_NAME=Mycee Accessories Stock Control
APP_VERSION=1.0

# Server Configuration
SERVER_HOST=localhost
SERVER_PORT=5000

# Email Configuration (optional)
MAIL_SERVER=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@myceaccessories.com
